#!/usr/bin/env bash
# Apply analytics Elasticsearch index template + bootstrap data stream.
#   ./cmd/define-elasticsearch           — local ES (127.0.0.1:9200, on mono host)
#   ./cmd/define-elasticsearch --on-mono — SSH to docs/project.yml mono.host
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
[[ -n "$ROOT" ]] || ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

# shellcheck source=lib/project.sh
source "${ROOT}/cmd/lib/project.sh"

TEMPLATE_FILE="${ROOT}/assets/elasticsearch/analytics-index-template.json"
ES="${ES_URL:-http://127.0.0.1:9200}"
SKIP_BOOTSTRAP="${SKIP_BOOTSTRAP:-0}"
REMOTE="${1:-}"

[[ -f "$TEMPLATE_FILE" ]] || { echo "[!] Missing $TEMPLATE_FILE"; exit 1; }

PROJECT_NAME="$(project_yaml_get project)"
DATA_STREAM="${PROJECT_NAME}-analytics"
TEMPLATE_ID="${DATA_STREAM}"
MONO_HOST="$(project_yaml_get mono.host)"
MONO_SSH_USER="${MONO_SSH_USER:-root}"
MONO_SSH="${MONO_SSH:-${MONO_SSH_USER}@${MONO_HOST}}"

apply_on_es() {
  echo "== Elasticsearch: $ES =="
  echo "== index template ($TEMPLATE_ID) =="
  curl -fS -X PUT "$ES/_index_template/$TEMPLATE_ID" \
    -H 'Content-Type: application/json' \
    --data-binary "@$TEMPLATE_FILE"
  echo

  if [[ "$SKIP_BOOTSTRAP" != "1" ]]; then
    echo "== bootstrap document → $DATA_STREAM =="
    curl -fS -X POST "$ES/$DATA_STREAM/_doc?refresh=wait_for" \
      -H 'Content-Type: application/json' \
      -d "{\"@timestamp\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"event\":\"import_bootstrap\"}"
    echo
  fi

  echo "== data stream =="
  curl -fS "$ES/_data_stream/$DATA_STREAM"
  echo

  echo "== field caps =="
  curl -fS "$ES/$DATA_STREAM/_field_caps?fields=event,@timestamp"
  echo
  echo "[+] OK — delete old Kibana saved objects, then import dashboards/kibana.ndjson"
}

if [[ "$REMOTE" == "--on-mono" ]]; then
  echo "== remote: $MONO_SSH =="
  scp "$TEMPLATE_FILE" "${MONO_SSH}:/tmp/secretchatonly-bot-analytics-template.json"
  ssh "$MONO_SSH" \
    "ES_URL=${ES_URL:-http://127.0.0.1:9200} SKIP_BOOTSTRAP=${SKIP_BOOTSTRAP} DATA_STREAM=${DATA_STREAM} TEMPLATE_ID=${TEMPLATE_ID} bash -s" <<'REMOTE'
set -euo pipefail
ES="${ES_URL:-http://127.0.0.1:9200}"
echo "== index template (${TEMPLATE_ID}) =="
curl -fS -X PUT "$ES/_index_template/$TEMPLATE_ID" \
  -H 'Content-Type: application/json' \
  --data-binary @/tmp/secretchatonly-bot-analytics-template.json
echo
if [[ "${SKIP_BOOTSTRAP}" != "1" ]]; then
  echo "== bootstrap document → ${DATA_STREAM} =="
  curl -fS -X POST "$ES/${DATA_STREAM}/_doc?refresh=wait_for" \
    -H 'Content-Type: application/json' \
    -d "{\"@timestamp\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"event\":\"import_bootstrap\"}"
  echo
fi
echo "== data stream =="
curl -fS "$ES/_data_stream/${DATA_STREAM}"
echo
echo "== field caps =="
curl -fS "$ES/${DATA_STREAM}/_field_caps?fields=event,@timestamp"
echo
echo "[+] OK on mono"
REMOTE
  exit 0
fi

if ! curl -fS --connect-timeout 3 "$ES/_cluster/health" >/dev/null 2>&1; then
  echo "[!] Elasticsearch not reachable at $ES"
  echo "    From your laptop:  ./cmd/define-elasticsearch --on-mono"
  echo "    On mono host:      ./cmd/define-elasticsearch"
  exit 1
fi

apply_on_es
