#!/usr/bin/env bash
# Import dashboards/kibana.ndjson into mono Kibana (8.12).
#   ./cmd/import-kibana           — local Kibana (127.0.0.1:5601, on mono host)
#   ./cmd/import-kibana --on-mono — SSH + curl import on mono
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
[[ -n "$ROOT" ]] || ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

# shellcheck source=lib/project.sh
source "${ROOT}/cmd/lib/project.sh"

NDJSON="${ROOT}/dashboards/kibana.ndjson"
KIBANA_URL="${KIBANA_URL:-http://127.0.0.1:5601}"
REMOTE="${1:-}"

[[ -f "$NDJSON" ]] || { echo "[!] Missing $NDJSON"; exit 1; }

MONO_HOST="$(project_yaml_get mono.host)"
MONO_SSH_USER="${MONO_SSH_USER:-root}"
MONO_SSH="${MONO_SSH:-${MONO_SSH_USER}@${MONO_HOST}}"

import_ndjson() {
  local url="$1" file="$2"
  echo "== Kibana import: $url =="
  local tmp http_code resp
  tmp="$(mktemp)"
  http_code="$(curl -sS -o "$tmp" -w '%{http_code}' \
    -X POST "${url}/api/saved_objects/_import?overwrite=true" \
    -H 'kbn-xsrf: true' \
    --form "file=@${file}")" || http_code="000"
  resp="$(cat "$tmp")"
  rm -f "$tmp"
  echo "$resp" | jq . 2>/dev/null || echo "$resp"
  if [[ "$http_code" -lt 200 || "$http_code" -ge 300 ]]; then
    echo "[!] HTTP $http_code"
    exit 1
  fi
  if echo "$resp" | grep -q '"success":true'; then
    echo "[+] Import OK"
    return 0
  fi
  echo "[!] Import reported errors — delete conflicting saved objects in Kibana UI, then retry"
  exit 1
}

if [[ "$REMOTE" == "--on-mono" ]]; then
  echo "== remote: $MONO_SSH =="
  scp "$NDJSON" "${MONO_SSH}:/tmp/secretchatonly-bot-kibana.ndjson"
  ssh "$MONO_SSH" "KIBANA_URL=${KIBANA_URL:-http://127.0.0.1:5601} bash -s" <<'REMOTE'
set -euo pipefail
KIBANA_URL="${KIBANA_URL:-http://127.0.0.1:5601}"
NDJSON="/tmp/secretchatonly-bot-kibana.ndjson"
until curl -sf "${KIBANA_URL}/api/status" >/dev/null 2>&1; do sleep 2; done
tmp="$(mktemp)"
http_code="$(curl -sS -o "$tmp" -w '%{http_code}' \
  -X POST "${KIBANA_URL}/api/saved_objects/_import?overwrite=true" \
  -H 'kbn-xsrf: true' \
  --form "file=@${NDJSON}")" || http_code="000"
resp="$(cat "$tmp")"
rm -f "$tmp"
echo "$resp"
if command -v jq >/dev/null 2>&1; then echo "$resp" | jq .; fi
[[ "$http_code" -ge 200 && "$http_code" -lt 300 ]] || { echo "[!] HTTP $http_code"; exit 1; }
echo "$resp" | grep -q '"success":true' || exit 1
echo "[+] OK on mono"
REMOTE
  exit 0
fi

if ! curl -sf --connect-timeout 3 "${KIBANA_URL}/api/status" >/dev/null 2>&1; then
  echo "[!] Kibana not reachable at $KIBANA_URL"
  echo "    From your laptop:  ./cmd/import-kibana --on-mono"
  echo "    On mono host:      ./cmd/import-kibana"
  exit 1
fi

import_ndjson "$KIBANA_URL" "$NDJSON"
