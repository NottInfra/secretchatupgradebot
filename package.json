{
  "name": "secretchatonly-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/root.js",
    "dev": "NODE_ENV=development tsx watch src/root.ts",
    "ops:create-db": "tsx src/zz-ops/create-db.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/rds-signer": "^3.917.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "pg": "^8.16.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.219.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "telegraf": "^4.16.3",
    "telegram": "^2.26.22",
    "zod": "^4.3.6"
  },
  "overrides": {
    "fast-xml-builder": "1.1.7",
    "@opentelemetry/exporter-prometheus": "0.219.0",
    "@opentelemetry/sdk-node": "0.219.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
