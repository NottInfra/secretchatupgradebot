NODE_ENV=development
# Optional: load secrets from Vault instead of .env.development
# VAULT_ADDR=http://mono:8090
# VAULT_READ_TOKEN=
# VAULT_PROJECT=dev-secretchatonly-bot
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres
DATABASE_SSL=
LOG_LEVEL=info
PORT=3000

TELEGRAM_API_ID=
TELEGRAM_API_HASH=

SESSION_PROVIDER_URL=
SESSION_PROVIDER_USER_ID=
SESSION_PROVIDER_API_KEY=
SESSION_PROVIDER_SVC_NAME=
# Path to sessionprovider repo — resolves relative sessionPath values from the SDK
SESSION_PROVIDER_ROOT=

MESSAGE_INSTANCE_COLLAPSE_SECONDS=30

MGMT_BOT_TOKEN=

# CI only — SonarQube scan on mono (apply-env-file-hashicorp → GitHub/GitLab secret)
SONAR_TOKEN=

# --- Observability (mono stack — apply-dashboards / apply-alerts; → Vault via apply-env-file-hashicorp) ---
# URLs are mono localhost — scripts SSH to mono then curl these from there.
ES_URL=
KIBANA_URL=
GRAFANA_URL=
GRAFANA_ADMIN_USER=
GRAFANA_ADMIN_PASSWORD=
# Optional — only if Elasticsearch security is enabled on mono:
# ELASTIC_USER=elastic
# ELASTIC_PASSWORD=
